{
    "name": "acseo/sylius-prometheus-metrics-plugin",
    "type": "sylius-plugin",
    "keywords": [
        "sylius",
        "sylius-plugin",
        "sylius-observability",
        "sylius-metrics",
        "sylius-prometheus"
    ],
    "description": "Sylius Prometheus Metrics Plugin",
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "sylius/sylius": "^1.14 || ^2.0",
        "artprima/prometheus-metrics-bundle": "~1.21.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.2"
    },
    "config": {
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "ACSEO\\SyliusPrometheusMetricsPlugin\\": "src/",
            "Tests\\ACSEO\\SyliusPrometheusMetricsPlugin\\": "tests/"
        }
    },
    "scripts": {
        "phpunit": "phpunit tests/PHPUnit"
    }
}
